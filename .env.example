# ─────────────────────────────────────────────────────────────
# FYB Hive — environment variables
# Copy to `.env.local` and fill in real values. Never commit secrets.
# ─────────────────────────────────────────────────────────────

# Supabase (server-side only — service role bypasses RLS; do NOT expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin session — secret used to sign the httpOnly admin cookie.
# Generate one, e.g.:  openssl rand -hex 32
ADMIN_COOKIE_SECRET=replace-with-a-long-random-string

# Cloudinary (profile/registration photo uploads + face detection)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
